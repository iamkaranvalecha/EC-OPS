# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ecops
TEST_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ecops_test

# ── LM Studio (local AI) ──────────────────────────────────────────────────────
# Start LM Studio, load a model, and enable the server (default port 1234).
# The Anthropic-compatible endpoint is used; api_key can be any non-empty string.
ANTHROPIC_API_KEY=lmstudio
LMSTUDIO_BASE_URL=http://localhost:1234
LM_MODEL=Qwen/Qwen2.5-7B-Instruct-GGUF

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8002
